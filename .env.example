# Secure Execution Gateway (.env.example)
#
# Runtime: Python 3.12
# Copy this file to `.env` and fill secrets - DO NOT commit `.env`.
#
# Notes:
# - `python-magic` requires the system `libmagic` library. In Debian/Ubuntu install
#   `libmagic1` (and optionally `libmagic-dev`) or the equivalent for your distro.
# - Paths must be relative in API requests; `SEG_FS_ROOT` is the absolute mount point
#   inside the container where allowed subdirectories live.
# - `SEG_ALLOWED_SUBDIRS` is a CSV list of allowed top-level subdirectories under
#   `SEG_FS_ROOT` (no leading slashes). Example: `uploads,output`.

########## Required (must be set) ##########
# Bearer token used to authorize requests to SEG. Provide a strong secret here.
# Generate using "openssl rand -hex 32" or similar.
SEG_API_TOKEN=generate-a-strong-token

# Absolute path inside the container where SEG will operate on files.
# Default for development / docker-compose use: /data
SEG_FS_ROOT=/data

# CSV of allowed subdirectories under SEG_FS_ROOT. Example: uploads,output
SEG_ALLOWED_SUBDIRS=uploads,output

########## Optional / Tunables ##########
# Maximum allowed file size in bytes (default: 100 MB)
SEG_MAX_BYTES=104857600

# Request timeout in milliseconds (default: 5000)
SEG_TIMEOUT_MS=5000

# Rate limit: requests per second per client (default: 10)
SEG_RATE_LIMIT_RPS=10

# Logging level: DEBUG, INFO, WARNING, ERROR
SEG_LOG_LEVEL=INFO

########## Operational notes ##########
# - For production, mount a directory at the host and map it to `SEG_FS_ROOT` in
#   your container runtime (read-write as needed). Ensure ownership and permissions
#   follow the principle of least privilege.
# - Do NOT store real secrets in the repo. Keep `.env` local and/or use a secret
#   manager for production deployments.
# - Ensure the container image includes the system `libmagic` package so
#   `python-magic` can detect MIME types by content.
