# =============================================================================
# Secure Execution Gateway (SEG) - Environment Configuration
#
# Runtime: Python 3.12
#
# Copy this file to `.env` and populate secrets.
# NEVER commit the `.env` file to version control.
# =============================================================================
#
# Notes:
# - SEG is designed to run as a rootless container.
# - Filesystem access is restricted to a sandbox rooted at SEG_SANDBOX_DIR.
# - Only explicitly allowlisted subdirectories are accessible via the API.
# - This file documents both REQUIRED and OPTIONAL configuration.
#
# =============================================================================


# =============================================================================
# Container Identity (Non-Root Execution)
# -----------------------------------------------------------------------------
# SEG always runs as a non-root user to reduce privilege and blast radius.
# These values define the security identity of the container and MUST be
# consistent with host-side volume permissions.
# =============================================================================

# Non-root user and group name inside the container
NON_ROOT_USER=seg
NON_ROOT_GROUP=seg

# Fixed UID/GID for deterministic permissions and shared-volume access
# NOTE:
# - Host-mounted volumes MUST use this GID for group ownership
# - setgid MUST be enabled on shared directories
NON_ROOT_UID=1001
NON_ROOT_GID=1001


# =============================================================================
# Docker / Compose Infrastructure
# -----------------------------------------------------------------------------
# Variables that define how SEG integrates into a Docker Compose stack.
# These values are consumed by docker-compose.yml, not by the application code.
# =============================================================================

# Docker Compose project name (used as a namespace for containers and volumes)
COMPOSE_PROJECT_NAME=seg

# Name of the pre-existing Docker network used to connect internal services
# (e.g. n8n, SEG, other microservices)
SHARED_DOCKER_NETWORK=docker-network

# Logical name for the shared Docker volume used by SEG and other services.
# The final Docker volume name will be:
#   <COMPOSE_PROJECT_NAME>_<SHARED_VOLUME_SUFFIX>
SHARED_VOLUME_SUFFIX=shared-data

# Fully-qualified Docker volume name (derived; do not change unless you know why)
SHARED_VOLUME_NAME=${COMPOSE_PROJECT_NAME}_${SHARED_VOLUME_SUFFIX}

# =============================================================================
# Security / Authentication
# -----------------------------------------------------------------------------
# SEG uses a single bearer token for internal service authentication.
# This token MUST be kept secret.
# =============================================================================

# SEG_API_TOKEN is loaded from Docker secret:
#   /run/secrets/seg_api_token
#
# Create the local secret file (never commit real values):
#   mkdir -p secrets
#   openssl rand -hex 32 > secrets/seg_api_token.txt
#
# Development-only fallback (used only when Docker secret is missing):
# SEG_API_TOKEN_DEV=


# =============================================================================
# Filesystem Sandbox Configuration
# -----------------------------------------------------------------------------
# Defines where SEG is allowed to operate on the filesystem.
# All file operations are strictly confined to this sandbox.
# =============================================================================

# Absolute path inside the container where the shared volume is mounted.
# The underlying volume MUST be prepared on the host with:
# - group ownership = NON_ROOT_GID (defined above)
# - setgid enabled
# to allow safe read/write access from SEG and other services.
SEG_SANDBOX_DIR=/data

# CSV list of allowed top-level subdirectories under SEG_SANDBOX_DIR.
# - No leading slashes
# - No nested paths
# Example:
#   uploads,output,tmp
#   * (to allow volume root and all subdirectories - NOT RECOMMENDED)
SEG_ALLOWED_SUBDIRS=uploads,output,tmp


# =============================================================================
# Runtime Limits & Safeguards
# -----------------------------------------------------------------------------
# Hard limits to reduce blast radius and prevent abuse or accidental overload.
# =============================================================================

# Maximum allowed file size (in bytes) for file-based operations.
# Default: 100 MB
SEG_MAX_BYTES=104857600

# Maximum execution time per request (in milliseconds).
# Requests exceeding this time will be aborted.
SEG_TIMEOUT_MS=5000

# Rate limit: maximum number of requests per second per client.
SEG_RATE_LIMIT_RPS=10


# =============================================================================
# Logging & Runtime Behavior
# -----------------------------------------------------------------------------
# Controls logging verbosity and runtime behavior.
# =============================================================================

# Logging level: DEBUG | INFO | WARNING | ERROR
SEG_LOG_LEVEL=INFO

# Application semantic version used in runtime metadata/OpenAPI docs.
# Format: x.y.z
SEG_APP_VERSION=0.1.0

# Internal port where the FastAPI application listens inside the container.
# This port is NOT exposed publicly; it is used for internal Docker networking.
SEG_PORT=8080

# Container timezone
TZ=America/Monterrey

# Runtime environment mode.
# Used to switch between different .env variants if needed.
# Options:
#   prod  -> .env
#   dev   -> .env.local
#   test  -> .env.test
ENV_MODE=prod


# =============================================================================
# API Docs / Runtime UI toggle
# -----------------------------------------------------------------------------
# Controls whether FastAPI's interactive documentation endpoints are enabled
# =============================================================================

# When `SEG_ENABLE_DOCS` is `true`, the runtime will expose the
# `/docs`, `/redoc` and `/openapi.json` endpoints without authentication
# (useful for local development and internal testing).
# Default: `false` (recommended for production).
SEG_ENABLE_DOCS=false

# =============================================================================
# Response Security Headers
# -----------------------------------------------------------------------------
# Controls baseline security headers and stack-fingerprinting header removal.
# =============================================================================

# When `SEG_ENABLE_SECURITY_HEADERS` is `true`, SEG adds baseline response
# security headers and removes `Server` / `X-Powered-By` from all HTTP responses.
# Default: `true` (recommended for production).
SEG_ENABLE_SECURITY_HEADERS=true

# =============================================================================
