{
  "openapi": "3.1.0",
  "info": {
    "title": "Secure Execution Gateway (SEG)",
    "description": "Secure Execution Gateway (SEG) is a hardened execution microservice designed to expose a strictly allow-listed action surface for automation platforms and internal systems.\n\nIt enforces:\n- Explicit action registry (no arbitrary command execution)\n- Defense-in-depth middleware stack\n- Deterministic response envelopes\n- Centralized error taxonomy\n- Observability-first architecture\n- Runtime-aware OpenAPI contract generation",
    "version": "0.1.0",
    "contact": {
      "name": "Libertocrat",
      "url": "https://github.com/Libertocrat/",
      "email": "libertocrat@proton.me"
    },
    "license": {
      "name": "Apache License 2.0",
      "url": "https://www.apache.org/licenses/LICENSE-2.0.html"
    }
  },
  "paths": {
    "/health": {
      "get": {
        "tags": [
          "Observability"
        ],
        "summary": "Health",
        "description": "Health check endpoint.\n\nReturns a minimal readiness payload as defined in the SRS.\n\nReturns:\n    A JSONResponse containing the readiness status, e.g. `{\"status\": \"ok\"}`.",
        "operationId": "health_health_get",
        "responses": {
          "200": {
            "description": "Health success response",
            "content": {
              "application/json": {
                "schema": {
                  "example": {
                    "success": true,
                    "error": null,
                    "data": {
                      "status": "ok"
                    }
                  }
                }
              }
            }
          }
        },
        "security": []
      }
    },
    "/metrics": {
      "get": {
        "tags": [
          "Observability"
        ],
        "summary": "Metrics",
        "description": "Prometheus metrics exposition endpoint.\n\nThis endpoint returns the current Prometheus metrics snapshot for the\nrunning process using the `prometheus_client` library.\n\nReturns:\n    A Starlette Response with the metrics payload and Prometheus content\n    type (`CONTENT_TYPE_LATEST`).",
        "operationId": "metrics_metrics_get",
        "responses": {
          "200": {
            "description": "Prometheus metrics snapshot",
            "content": {
              "text/plain": {
                "schema": {
                  "type": "string",
                  "example": "# HELP http_requests_total ...\n# TYPE http_requests_total counter\nhttp_requests_total 42\n# HELP ...\n"
                }
              }
            }
          }
        },
        "security": [],
        "externalDocs": {
          "description": "Prometheus scraping documentation",
          "url": "https://prometheus.io/docs/prometheus/latest/configuration/configuration/#scrape_config"
        }
      }
    },
    "/v1/execute": {
      "post": {
        "tags": [
          "Execution"
        ],
        "summary": "Execute",
        "description": "Executes a registered SEG action within the secure sandbox environment.\n\n### Supported Actions\n\n- `file_checksum`: Compute a sandboxed file checksum\n- `file_delete`: Delete a file from the sandbox\n- `file_move`: Move a file within the sandbox\n- `file_mime_detect`: Detect file MIME type by content\n- `file_verify`: Verify file type and optional checksum",
        "operationId": "execute_v1_execute_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "oneOf": [
                  {
                    "type": "object",
                    "description": "\nComputes a streaming checksum for a file located inside the SEG sandbox.\n\nThis action:\n\n- Enforces strict sandbox path boundaries\n- Rejects unsafe path traversal and symlink patterns\n- Applies `SEG_MAX_BYTES` size constraints\n- Supports configurable hashing algorithms (e.g. sha256, md5, sha1)\n\nReturns structured metadata including:\n\n- Algorithm used\n- Hex digest\n- File size in bytes\n",
                    "properties": {
                      "action": {
                        "type": "string",
                        "const": "file_checksum"
                      },
                      "params": {
                        "$ref": "#/components/schemas/ChecksumParams"
                      }
                    },
                    "required": [
                      "action",
                      "params"
                    ]
                  },
                  {
                    "type": "object",
                    "description": "\nDeletes a regular file within the SEG sandbox under strict security controls.\n\nThis action:\n\n- Validates the target path against sandbox boundaries\n- Rejects symlink traversal and unsafe patterns\n- Supports idempotent behavior when `require_exists=false`\n- Returns whether the deletion actually occurred\n\nDesigned for safe lifecycle management of sandboxed files.\n",
                    "properties": {
                      "action": {
                        "type": "string",
                        "const": "file_delete"
                      },
                      "params": {
                        "$ref": "#/components/schemas/DeleteParams"
                      }
                    },
                    "required": [
                      "action",
                      "params"
                    ]
                  },
                  {
                    "type": "object",
                    "description": "\nMoves a file between paths inside the SEG sandbox with strict policy enforcement.\n\nThis action:\n\n- Validates both source and destination paths\n- Enforces sandbox boundaries\n- Preserves file extension integrity\n- Supports controlled overwrite behavior\n\nDesigned for safe internal file lifecycle operations without exposing\nraw filesystem primitives.\n",
                    "properties": {
                      "action": {
                        "type": "string",
                        "const": "file_move"
                      },
                      "params": {
                        "$ref": "#/components/schemas/FileMoveParams"
                      }
                    },
                    "required": [
                      "action",
                      "params"
                    ]
                  },
                  {
                    "type": "object",
                    "description": "\nDetects the MIME type of a sandboxed file using content-based inspection.\n\nUnlike extension-based heuristics, this action relies on content analysis\n(e.g. libmagic) for accurate detection.\n\nSecurity and policy enforcement:\n\n- Enforces sandbox boundaries\n- Applies `SEG_MAX_BYTES` size constraints\n- Rejects unsafe path traversal patterns\n\nReturns the detected MIME type for downstream validation workflows.\n",
                    "properties": {
                      "action": {
                        "type": "string",
                        "const": "file_mime_detect"
                      },
                      "params": {
                        "$ref": "#/components/schemas/MimeDetectParams"
                      }
                    },
                    "required": [
                      "action",
                      "params"
                    ]
                  },
                  {
                    "type": "object",
                    "description": "\nPerforms composite verification of a sandboxed file.\n\nThis action combines multiple validation layers:\n\n- MIME type detection (content-based)\n- Extension allowlist enforcement\n- MIME allowlist enforcement\n- Optional checksum validation\n\nReturns a structured decision model including:\n\n- Detected MIME type\n- Extension validation result\n- MIME allowlist compliance\n- Optional checksum comparison outcome\n- Final verification status\n\nDesigned for secure ingestion and validation pipelines.\n",
                    "properties": {
                      "action": {
                        "type": "string",
                        "const": "file_verify"
                      },
                      "params": {
                        "$ref": "#/components/schemas/FileVerifyParams"
                      }
                    },
                    "required": [
                      "action",
                      "params"
                    ]
                  }
                ],
                "discriminator": {
                  "propertyName": "action"
                }
              },
              "examples": {
                "file_checksum": {
                  "summary": "file_checksum: Compute a sandboxed file checksum",
                  "description": "\nComputes a streaming checksum for a file located inside the SEG sandbox.\n\nThis action:\n\n- Enforces strict sandbox path boundaries\n- Rejects unsafe path traversal and symlink patterns\n- Applies `SEG_MAX_BYTES` size constraints\n- Supports configurable hashing algorithms (e.g. sha256, md5, sha1)\n\nReturns structured metadata including:\n\n- Algorithm used\n- Hex digest\n- File size in bytes\n",
                  "value": {
                    "action": "file_checksum",
                    "params": {
                      "path": "relative/path/to/file.txt",
                      "algorithm": "sha256"
                    }
                  }
                },
                "file_delete": {
                  "summary": "file_delete: Delete a file from the sandbox",
                  "description": "\nDeletes a regular file within the SEG sandbox under strict security controls.\n\nThis action:\n\n- Validates the target path against sandbox boundaries\n- Rejects symlink traversal and unsafe patterns\n- Supports idempotent behavior when `require_exists=false`\n- Returns whether the deletion actually occurred\n\nDesigned for safe lifecycle management of sandboxed files.\n",
                  "value": {
                    "action": "file_delete",
                    "params": {
                      "path": "relative/path/to/file.txt",
                      "require_exists": false
                    }
                  }
                },
                "file_move": {
                  "summary": "file_move: Move a file within the sandbox",
                  "description": "\nMoves a file between paths inside the SEG sandbox with strict policy enforcement.\n\nThis action:\n\n- Validates both source and destination paths\n- Enforces sandbox boundaries\n- Preserves file extension integrity\n- Supports controlled overwrite behavior\n\nDesigned for safe internal file lifecycle operations without exposing\nraw filesystem primitives.\n",
                  "value": {
                    "action": "file_move",
                    "params": {
                      "source_path": "relative/path/to/source.txt",
                      "destination_path": "relative/path/to/destination.txt",
                      "overwrite": false
                    }
                  }
                },
                "file_mime_detect": {
                  "summary": "file_mime_detect: Detect file MIME type by content",
                  "description": "\nDetects the MIME type of a sandboxed file using content-based inspection.\n\nUnlike extension-based heuristics, this action relies on content analysis\n(e.g. libmagic) for accurate detection.\n\nSecurity and policy enforcement:\n\n- Enforces sandbox boundaries\n- Applies `SEG_MAX_BYTES` size constraints\n- Rejects unsafe path traversal patterns\n\nReturns the detected MIME type for downstream validation workflows.\n",
                  "value": {
                    "action": "file_mime_detect",
                    "params": {
                      "path": "relative/path/to/file.txt"
                    }
                  }
                },
                "file_verify": {
                  "summary": "file_verify: Verify file type and optional checksum",
                  "description": "\nPerforms composite verification of a sandboxed file.\n\nThis action combines multiple validation layers:\n\n- MIME type detection (content-based)\n- Extension allowlist enforcement\n- MIME allowlist enforcement\n- Optional checksum validation\n\nReturns a structured decision model including:\n\n- Detected MIME type\n- Extension validation result\n- MIME allowlist compliance\n- Optional checksum comparison outcome\n- Final verification status\n\nDesigned for secure ingestion and validation pipelines.\n",
                  "value": {
                    "action": "file_verify",
                    "params": {
                      "path": "relative/path/to/file.txt",
                      "expected_mime": "text/plain",
                      "allowed_extensions": [
                        ".txt",
                        ".md"
                      ],
                      "allowed_mime_types": [
                        "text/plain",
                        "text/markdown"
                      ],
                      "checksum": {
                        "expected": "5d41402abc4b2a76b9719d911017c592",
                        "algorithm": "md5"
                      }
                    }
                  }
                }
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    {
                      "$ref": "#/components/schemas/ResponseEnvelope"
                    },
                    {
                      "properties": {
                        "data": {
                          "oneOf": [
                            {
                              "$ref": "#/components/schemas/ChecksumResult"
                            },
                            {
                              "$ref": "#/components/schemas/DeleteResult"
                            },
                            {
                              "$ref": "#/components/schemas/FileMoveResult"
                            },
                            {
                              "$ref": "#/components/schemas/MimeDetectResult"
                            },
                            {
                              "$ref": "#/components/schemas/FileVerifyResult"
                            }
                          ]
                        }
                      }
                    }
                  ]
                },
                "examples": {
                  "file_checksum": {
                    "summary": "Response for action: file_checksum",
                    "value": {
                      "success": true,
                      "error": null,
                      "data": {
                        "algorithm": "sha256",
                        "checksum": "e3b0c44298fc1c149afbf4c8996fb92427ae41e4649b934ca495991b7852b855",
                        "size_bytes": 24817
                      }
                    }
                  },
                  "file_delete": {
                    "summary": "Response for action: file_delete",
                    "value": {
                      "success": true,
                      "error": null,
                      "data": {
                        "deleted": true
                      }
                    }
                  },
                  "file_move": {
                    "summary": "Response for action: file_move",
                    "value": {
                      "success": true,
                      "error": null,
                      "data": {
                        "moved": true,
                        "source": "relative/path/to/source.txt",
                        "destination": "relative/path/to/destination.txt"
                      }
                    }
                  },
                  "file_mime_detect": {
                    "summary": "Response for action: file_mime_detect",
                    "value": {
                      "success": true,
                      "error": null,
                      "data": {
                        "mime": "text/plain"
                      }
                    }
                  },
                  "file_verify": {
                    "summary": "Response for action: file_verify",
                    "value": {
                      "success": true,
                      "error": null,
                      "data": {
                        "file_verified": true,
                        "size_bytes": 2540,
                        "detected_mime": "text/plain",
                        "extension": ".txt",
                        "mime_matches": true,
                        "extension_allowed": true,
                        "mime_allowed": true,
                        "checksum_matches": true
                      }
                    }
                  }
                }
              }
            },
            "headers": {
              "X-Request-Id": {
                "description": "Request correlation identifier.",
                "schema": {
                  "type": "string",
                  "format": "uuid"
                }
              }
            }
